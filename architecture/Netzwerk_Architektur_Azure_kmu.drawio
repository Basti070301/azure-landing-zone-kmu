        <mxCell id="58AZMBCupwoDNQ2-KfPB-8" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Netzwerk Architektur (Dev)&lt;/h1&gt;&lt;p&gt;Dev-Netzwerksegment der Azure Landing Zone (KMU).&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;VNet ist in mgmt / app / data segmentiert.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Je Subnet schützt eine dedizierte NSG den Traffic nach dem Least-Privilege-Prinzip.&lt;/span&gt;&lt;/p&gt;" vertex="1">
